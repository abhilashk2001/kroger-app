// Prisma schema for the Kroger retail data model.
//
// Convention: model fields are camelCase (nice in TypeScript) and map to
// snake_case database columns/tables via @map / @@map.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// One row per household. Demographics are optional — many households have none.
model Household {
  hshdNum         Int     @id @map("hshd_num")
  loyaltyFlag     Boolean @map("loyalty_flag")
  ageRange        String? @map("age_range")
  marital         String?
  incomeRange     String? @map("income_range")
  homeowner       String?
  hshdComposition String? @map("hshd_composition")
  hhSize          String? @map("hh_size") // text: values are ranges like "5+"
  children        String? // text: values are ranges like "3+"

  transactions Transaction[]

  @@map("households")
}

/// One row per product in the catalog.
model Product {
  productNum Int     @id @map("product_num")
  department String
  commodity  String
  brandType  String  @map("brand_type") // PRIVATE | NATIONAL
  isOrganic  Boolean @map("is_organic")

  transactions Transaction[]

  @@map("products")
}

/// One row per product purchased, per basket (shopping trip).
model Transaction {
  id           Int      @id @default(autoincrement())
  basketNum    Int      @map("basket_num")
  hshdNum      Int      @map("hshd_num")
  productNum   Int      @map("product_num")
  purchaseDate DateTime @map("purchase_date") @db.Date
  spend        Decimal  @db.Decimal(10, 2) // money: exact, never float
  units        Int
  storeRegion  String   @map("store_region")
  weekNum      Int      @map("week_num")
  year         Int

  // Foreign keys: the database enforces that every transaction points at a
  // real household and a real product.
  household Household @relation(fields: [hshdNum], references: [hshdNum])
  product   Product   @relation(fields: [productNum], references: [productNum])

  // Indexes for the lookups later phases run (search, sort, basket analysis).
  @@index([hshdNum])
  @@index([basketNum])
  @@index([productNum])
  @@map("transactions")
}

/// Application users for authentication.
model User {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  email        String   @unique
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("users")
}

/// Market-basket association rules (commodity level), precomputed offline by
/// ml/basket_analysis.py. antecedents/consequents are comma-joined commodity lists
/// (stored as text — simpler to write from pandas than a Postgres array).
model BasketRule {
  id          Int      @id @default(autoincrement())
  antecedents String
  consequents String
  support     Float
  confidence  Float
  lift        Float
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("basket_rules")
}

/// Evaluation summary for the Gradient Boosting co-purchase model (one row per
/// target commodity). top_drivers is a comma-joined list of the most important
/// co-purchase commodities.
model BasketModelMetric {
  id              Int      @id @default(autoincrement())
  targetCommodity String   @map("target_commodity")
  accuracy        Float
  rocAuc          Float    @map("roc_auc")
  topDrivers      String   @map("top_drivers")
  createdAt       DateTime @default(now()) @map("created_at")

  @@map("basket_model_metric")
}
