# Copy this file to `.env` and adjust as needed. `.env` is git-ignored.

# ───────── Database (PostgreSQL) ─────────
POSTGRES_USER=kroger
POSTGRES_PASSWORD=kroger_dev_pw
POSTGRES_DB=kroger

# Connection string used by Prisma inside the API container.
# Host "db" is the docker-compose service name, NOT localhost — containers reach
# each other by service name on the compose network.
DATABASE_URL=postgresql://kroger:kroger_dev_pw@db:5432/kroger?schema=public
# Separate database used by the integration test suite.
TEST_DATABASE_URL=postgresql://kroger:kroger_dev_pw@db:5432/kroger_test?schema=public

# ───────── API ─────────
API_PORT=3000

# ───────── Web ─────────
WEB_PORT=5173
# URL the React app (running in your browser) uses to reach the API.
VITE_API_URL=http://localhost:3000
